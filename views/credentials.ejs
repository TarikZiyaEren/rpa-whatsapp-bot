<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Credentials — RPA Panel</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Segoe UI", sans-serif;
      background: #f0f4ff;
      color: #1e293b;
    }

    header {
      background: #1a237e;
      color: white;
      padding: 14px 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    header h1 {
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    nav a {
      color: #c7d2fe;
      text-decoration: none;
      margin-left: 18px;
      font-size: 0.92rem;
    }

    nav a:hover {
      color: white;
    }

    .hospital-badge {
      font-size: .78rem;
      background: #e8eaf6;
      color: #1a237e;
      padding: 4px 10px;
      border-radius: 999px;
      font-weight: 700;
    }

    .container {
      max-width: 960px;
      margin: 36px auto;
      padding: 0 16px;
    }

    .card {
      background: white;
      border-radius: 14px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,.08);
      margin-bottom: 20px;
    }

    .card h2 {
      color: #1a237e;
      margin-bottom: 18px;
      font-size: 1.08rem;
    }

    .msg {
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 18px;
      font-size: 0.95rem;
    }

    .msg.ok {
      background: #dcfce7;
      color: #166534;
      border-left: 4px solid #22c55e;
    }

    .msg.err {
      background: #fee2e2;
      color: #991b1b;
      border-left: 4px solid #ef4444;
    }

    label {
      display: block;
      margin-bottom: 6px;
      font-size: 0.92rem;
      color: #475569;
      font-weight: 600;
    }

    input, select {
      width: 100%;
      padding: 11px 13px;
      border: 1px solid #dbe2ea;
      border-radius: 10px;
      font-size: 0.98rem;
      margin-bottom: 14px;
      background: white;
    }

    input:focus, select:focus {
      outline: none;
      border-color: #4361ee;
    }

    .hint {
      font-size: 0.82rem;
      color: #64748b;
      margin-top: -8px;
      margin-bottom: 12px;
    }

    .field-box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      padding: 14px;
      margin-bottom: 14px;
    }

    .required {
      color: #dc2626;
      margin-left: 4px;
    }

    .btn {
      width: 100%;
      padding: 12px;
      background: #1a237e;
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
    }

    .btn:hover {
      background: #151b66;
    }

    .saved-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
    }

    .saved-item {
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 14px;
      background: #fafafa;
    }

    .saved-item strong {
      display: block;
      color: #0f172a;
      margin-bottom: 6px;
      text-transform: capitalize;
    }

    .saved-badge {
      display: inline-block;
      background: #dcfce7;
      color: #166534;
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .muted {
      color: #64748b;
      font-size: 0.92rem;
    }

    .top-info {
      margin-bottom: 14px;
      color: #475569;
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .schema-preview {
      background: #eef2ff;
      border: 1px solid #c7d2fe;
      color: #3730a3;
      border-radius: 10px;
      padding: 10px 12px;
      margin-bottom: 14px;
      font-size: 0.88rem;
      display: none;
    }

    .provider-meta {
      margin-top: -4px;
      margin-bottom: 14px;
      color: #64748b;
      font-size: 0.86rem;
    }

    .provider-help {
      margin-bottom: 16px;
      padding: 12px 14px;
      border-radius: 10px;
      background: #f8fafc;
      color: #475569;
      border: 1px solid #e2e8f0;
      font-size: .9rem;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <header>
    <h1>
      🔑 Credential Yönetimi
      <% if (typeof currentHospital !== "undefined" && currentHospital) { %>
        <span class="hospital-badge"><%= currentHospital.ad %></span>
      <% } %>
    </h1>

    <nav>
      <a href="/">🤖 Bot</a>
      <a href="/dashboard">📊 Dashboard</a>
      <a href="/history">📋 Geçmiş</a>
      <a href="/monitoring">📈 Monitoring</a>
      <a href="/logout">Çıkış</a>
    </nav>
  </header>

  <div class="container">
    <div class="card">
      <h2>Yeni Credential Kaydet</h2>

      <div class="top-info">
        Sigorta portalı seçtiğinde gerekli alanlar otomatik gelir. Kaydettiğin credential sadece aktif hastane ve mevcut kullanıcı bağlamında kullanılır.
      </div>

      <div class="provider-help">
        Önce provider seç, sonra istenen kullanıcı adı / şifre bilgilerini gir. Kaydetmeden provizyon formunda ilgili provider aktif görünmez.
      </div>

      <% if (ok) { %>
        <div class="msg ok">✅ <%= ok %></div>
      <% } %>

      <% if (hata) { %>
        <div class="msg err">❌ <%= hata %></div>
      <% } %>

      <form method="POST" action="/credentials" id="credentialForm">
        <label for="provider">Sigorta Portalı</label>
        <select name="provider" id="provider" required>
          <option value="">— Seçiniz —</option>
          <% providers.forEach(function(p) { %>
            <option
              value="<%= p.key %>"
              <%= formData && formData.provider === p.key ? "selected" : "" %>>
              <%= p.label %>
            </option>
          <% }) %>
        </select>

        <div id="providerMeta" class="provider-meta"></div>
        <div id="schemaPreview" class="schema-preview"></div>
        <div id="dynamicFields"></div>

        <button type="submit" class="btn">Kaydet</button>
      </form>
    </div>

    <div class="card">
      <h2>Kayıtlı Provider'lar</h2>

      <% if (!saved || !saved.length) { %>
        <div class="muted">Henüz kayıtlı credential yok.</div>
      <% } else { %>
        <div class="saved-list">
          <% saved.forEach(function(item) { %>
            <div class="saved-item">
              <strong><%= item %></strong>
              <span class="saved-badge">Kaydedildi</span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    const providers = <%- JSON.stringify(providers || []) %>;
    const formData = <%- JSON.stringify(formData || {}) %>;

    const providerSelect = document.getElementById("provider");
    const dynamicFields = document.getElementById("dynamicFields");
    const schemaPreview = document.getElementById("schemaPreview");
    const providerMeta = document.getElementById("providerMeta");

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function getProvider(providerKey) {
      return providers.find((p) => p.key === providerKey) || null;
    }

    function getSchema(provider) {
      if (!provider) return [];
      if (Array.isArray(provider.credentialSchema)) return provider.credentialSchema;
      if (Array.isArray(provider.schema)) return provider.schema;
      return [];
    }

    function renderSchemaPreview(provider) {
      const schema = getSchema(provider);

      if (!schema.length) {
        schemaPreview.style.display = "none";
        schemaPreview.innerHTML = "";
        providerMeta.textContent = "";
        return;
      }

      const zorunlu = schema
        .filter((x) => x.required)
        .map((x) => x.label || x.key);

      const opsiyonel = schema
        .filter((x) => !x.required)
        .map((x) => x.label || x.key);

      providerMeta.textContent = `${provider.label} için giriş alanları aşağıda oluşturuldu.`;

      schemaPreview.innerHTML = `
        <strong>Alan Özeti:</strong>
        ${zorunlu.length ? ` Zorunlu: ${escapeHtml(zorunlu.join(", "))}.` : ""}
        ${opsiyonel.length ? ` Opsiyonel: ${escapeHtml(opsiyonel.join(", "))}.` : ""}
      `;
      schemaPreview.style.display = "block";
    }

    function renderFields(providerKey) {
      const provider = getProvider(providerKey);
      const schema = getSchema(provider);

      if (!schema.length) {
        dynamicFields.innerHTML = "";
        renderSchemaPreview(null);
        return;
      }

      renderSchemaPreview(provider);

      dynamicFields.innerHTML = schema.map((field) => {
        const value = formData[field.key] || "";
        const requiredMark = field.required ? '<span class="required">*</span>' : "";
        const placeholder = field.placeholder || field.label || field.key;
        const inputType = field.type || "text";
        const autoComplete =
          field.key === "username" ? "username" :
          field.key === "password" ? "current-password" :
          "off";

        return `
          <div class="field-box">
            <label for="field_${escapeHtml(field.key)}">
              ${escapeHtml(field.label || field.key)} ${requiredMark}
            </label>
            <input
              id="field_${escapeHtml(field.key)}"
              name="${escapeHtml(field.key)}"
              type="${escapeHtml(inputType)}"
              value="${escapeHtml(value)}"
              placeholder="${escapeHtml(placeholder)}"
              ${field.required ? "required" : ""}
              autocomplete="${escapeHtml(autoComplete)}"
            />
            <div class="hint">
              ${field.required ? "Zorunlu alan" : "Opsiyonel alan"}
            </div>
          </div>
        `;
      }).join("");
    }

    providerSelect.addEventListener("change", function() {
      renderFields(this.value);
    });

    renderFields(providerSelect.value);
  </script>
</body>
</html>