  document.querySelector('input[name="islem_kodu"]').addEventListener("blur", canliRiskTahminiYap);
  document.querySelector('input[name="islem_adi"]').addEventListener("blur", canliRiskTahminiYap);
  doktorNotuInput.addEventListener("input", aiAnalizPlanla);
  doktorNotuInput.addEventListener("blur", () => {
    aiAnalizPlanla();
