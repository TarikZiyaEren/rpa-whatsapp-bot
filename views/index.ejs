        if (!resp.ok || !data.ok) {
          hbysKlinikKutuTemizle();
          hbysMesajYaz(data.hata || "Hasta verisi bulunamadı.", true);
          return;
        }

        adEl.value = data.hasta?.ad || "";
        dogumEl.value = data.hasta?.dogum || "";

        if (!notEl.value && data.doktorNotu) {
          notEl.value = data.doktorNotu;
        }

        hbysKlinikKutuGoster(data);
        hbysMesajYaz(`Hasta bilgileri ${data.kaynak || "FHIR_MOCK"} kaynağından dolduruldu.`);
        aiAnalizPlanla();
        canliRiskTahminiYap();
      } catch (_err) {
        hbysKlinikKutuTemizle();
        hbysMesajYaz("HBYS bağlantısı sırasında hata oluştu.", true);
      }
    });
  }

  if (onerBtn) {
    onerBtn.addEventListener("click", async () => {
      const not = doktorNotuInput.value.trim();

      if (!not) {
        oneriMesajYaz("Önce doktor notu gir.", true);
        return;
      }

      try {
        oneriMesajYaz("AI işlem önerileri hazırlanıyor...");

        const resp = await fetch("/api/islem-oneri", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ doktorNotu: not })
        });

        const data = await resp.json();

        if (!resp.ok || !data.ok || !data.oneriler?.length) {
          oneriMesajYaz("Uygun işlem önerisi bulunamadı.", true);
          return;
        }

        oneriMesajYaz(`
          <h3>🧠 AI İşlem Önerileri</h3>
          ${data.oneriler.map(o => `
            <div class="oner-item" data-kod="${escapeHtml(o.kod)}" data-ad="${escapeHtml(o.ad)}">
              <strong>${escapeHtml(o.ad)}</strong>
              <div style="color:#0f766e;font-size:.85rem">${escapeHtml(o.kod)}</div>
            </div>
          `).join("")}
        `);
      } catch (_e) {
        oneriMesajYaz("İşlem önerisi alınırken hata oluştu.", true);
      }
    });

    document.addEventListener("click", (e) => {
      const item = e.target.closest(".oner-item");
      if (!item) return;

      islemKoduInput.value = item.dataset.kod;
      islemAdiInput.value = item.dataset.ad;
      hiddenAiSeciliOneriKodu.value = item.dataset.kod || "";
      hiddenAiSeciliOneriAd.value = item.dataset.ad || "";
      icdGoster(item.dataset.kod);
      canliRiskTahminiYap();

      oneriMesajYaz(`✅ <strong>${escapeHtml(item.dataset.ad)}</strong> seçildi. SUT kodu otomatik dolduruldu.`);
    });
  }

  aiSutListesi.addEventListener("click", (e) => {
    const btn = e.target.closest(".ai-apply-btn");
    if (!btn) return;

    islemKoduInput.value = btn.dataset.kod;
    islemAdiInput.value = btn.dataset.ad;
    hiddenAiSeciliOneriKodu.value = btn.dataset.kod || "";
    hiddenAiSeciliOneriAd.value = btn.dataset.ad || "";
    icdGoster(btn.dataset.kod);
    canliRiskTahminiYap();

    oneriMesajYaz(`✅ <strong>${escapeHtml(btn.dataset.ad)}</strong> AI panelinden seçildi. SUT kodu forma aktarıldı.`);
  });

  document.querySelector('input[name="tc"]').addEventListener("blur", canliRiskTahminiYap);
  document.querySelector('input[name="ad"]').addEventListener("blur", canliRiskTahminiYap);
  document.querySelector('select[name="provider"]').addEventListener("change", canliRiskTahminiYap);
  document.querySelector('input[name="dogum"]').addEventListener("blur", () => {
    aiAnalizPlanla();
