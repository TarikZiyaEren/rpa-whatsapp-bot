  function renderGerekcePdf(gerekcePdf) {
    if (!gerekcePdf || !gerekcePdf.filePath) return "";

    const rawPath = String(gerekcePdf.filePath || "");
    const normalizedPath = rawPath.replaceAll("\\", "/");
    const parts = normalizedPath.split("/");
    const fileName = parts[parts.length - 1] || "";

    if (!fileName) return "";

    return `
      <div class="uyari" style="margin-top:12px;background:#eef6ff;color:#174ea6;border:1px solid #cfe2ff;">
        <h3>📄 AI Gerekçe PDF</h3>
        <p><strong>Belge No:</strong> ${escapeHtml(gerekcePdf.belgeNo || "-")}</p>
        <a class="pdf-link" href="/generated_docs/${encodeURIComponent(fileName)}" target="_blank" rel="noopener noreferrer">
          PDF İndir / Aç
        </a>
      </div>
    `;
  }

  function renderAiRapor(rapor) {
    if (!rapor) return "";

    const eksik = (rapor.eksikBelgeler || []).length ? rapor.eksikBelgeler.join(", ") : "—";
    const yuzde = (rapor.finalRisk != null) ? Math.round(rapor.finalRisk * 100) : "—";
    const gerekce = rapor.gerekce?.gerekceMetni || rapor.gerekce?.gerekce || null;
    const nedenler = (rapor.nedenler || []).length
      ? `<ul class="neden-listesi">${rapor.nedenler.map(n => `<li>${escapeHtml(n)}</li>`).join("")}</ul>`
      : "<p><strong>Neden:</strong> Standart işlem akışı.</p>";
    const ogrenme = rapor.ogrenmePuani
      ? `<p><strong>Self-Learning Etkisi:</strong> ${escapeHtml(Math.round(rapor.ogrenmePuani * 100))}%</p>`
      : "";

    const icdBilgiHtml =
      rapor.icdKodu || rapor.icdAd
        ? `<p><strong>ICD:</strong> ${escapeHtml(rapor.icdKodu || "-")}${rapor.icdAd ? ` - ${escapeHtml(rapor.icdAd)}` : ""}</p>`
        : "";

    return `
      <div class="uyari" style="margin-top:12px;">
        <h3>🧠 AI Analiz</h3>
        <div class="mini-grid">
          <div class="mini-card">
            <strong>Risk</strong>
            <div>${escapeHtml(rapor.seviye)} (%${escapeHtml(yuzde)})</div>
          </div>
          <div class="mini-card">
            <strong>ML Skoru</strong>
            <div>${rapor.mlSkoru != null ? `%${Math.round(rapor.mlSkoru * 100)}` : "-"}</div>
          </div>
          <div class="mini-card">
            <strong>LLM Skoru</strong>
            <div>${rapor.aiSkoru != null ? `%${Math.round(rapor.aiSkoru * 100)}` : "-"}</div>
          </div>
        </div>
        ${icdBilgiHtml}
        <p><strong>Öneri:</strong> ${escapeHtml(rapor.oneri || "—")}</p>
        <p><strong>Eksik Belgeler:</strong> ${escapeHtml(eksik)}</p>
        ${ogrenme}
        <details style="margin-top:8px;">
          <summary>Detaylı analiz nedenleri</summary>
          ${nedenler}
        </details>
        ${gerekce ? `<details><summary>📝 Gerekçe Taslağı</summary><pre>${escapeHtml(gerekce)}</pre></details>` : ""}
      </div>`;
  }

  function renderRedCozum(redCozum) {
    if (!redCozum) return "";

    const nedenler = (redCozum.nedenler || []).map(n => `<li>${escapeHtml(n)}</li>`).join("");
    const sutlar = (redCozum.alternatifSutlar || []).map(s =>
      `<li><strong>${escapeHtml(s.kod)}</strong> — ${escapeHtml(s.ad)}</li>`
    ).join("");
    const notlar = (redCozum.doktorNotuOnerileri || []).map(n => `<li>${escapeHtml(n)}</li>`).join("");
    const belgeler = (redCozum.belgeOnerileri || []).map(b => `<li>${escapeHtml(b)}</li>`).join("");

    return `
      <div class="uyari" style="margin-top:12px;background:#eef6ff;color:#174ea6;border:1px solid #cfe2ff;">
        <h3>🛠 AI RED Çözüm Önerisi</h3>
        <p><strong>Hata:</strong> ${escapeHtml(redCozum.hataKodu || "—")} - ${escapeHtml(redCozum.hataMesaji || "—")}</p>
        ${nedenler ? `<details open><summary>Muhtemel Nedenler</summary><ul class="neden-listesi">${nedenler}</ul></details>` : ""}
        ${sutlar ? `<details><summary>Alternatif SUT Kodları</summary><ul class="neden-listesi">${sutlar}</ul></details>` : ""}
        ${notlar ? `<details><summary>Doktor Notu İyileştirme</summary><ul class="neden-listesi">${notlar}</ul></details>` : ""}
        ${belgeler ? `<details><summary>Önerilen Belgeler</summary><ul class="neden-listesi">${belgeler}</ul></details>` : ""}
      </div>
    `;
  }

  function renderRetryBilgi(retryBilgi) {
    if (!retryBilgi || !retryBilgi.denendi) return "";

    const yeniIslem = retryBilgi.yeniIslem
      ? `${escapeHtml(retryBilgi.yeniIslem.kodu || "—")} - ${escapeHtml(retryBilgi.yeniIslem.adi || "—")}`
      : "—";

    const durum = escapeHtml(retryBilgi.retryDurum || "—");
    const takipNo = escapeHtml(retryBilgi.retryTakipNo || "—");
    const hata = retryBilgi.retryHataMesaji
      ? `<p><strong>Retry Hata:</strong> ${escapeHtml(retryBilgi.retryHataMesaji)}</p>`
      : "";

    const basarili = String(retryBilgi.retryDurum || "").toUpperCase().includes("ONAY");

    return `
      <div class="${basarili ? "basarili" : "uyari"}" style="margin-top:12px;">
        <h3>🔁 Otomatik Yeniden Deneme</h3>
        <p><strong>Yeni SUT:</strong> ${yeniIslem}</p>
        <p><strong>Retry Sonuç:</strong> ${durum}</p>
        <p><strong>Retry Takip No:</strong> ${takipNo}</p>
        ${hata}
      </div>
    `;
  }

  function renderSonucOzeti(r) {
    const aiContext = r.aiContext || {};
    const finalIslem = r.finalIslem || {};
    const klinikVeri = r.klinikVeri || {};
    const imzaKaydi = r.imzaKaydi || null;

    const icdKodu = r.rapor?.icdKodu || aiContext.icdKodu || "";
    const icdAd = r.rapor?.icdAd || aiContext.icdAd || "";

    const secilenSut =
      finalIslem?.kodu || finalIslem?.adi
        ? `${finalIslem.kodu || "-"}${finalIslem.adi ? ` - ${finalIslem.adi}` : ""}`
        : aiContext.seciliOneriKodu
          ? `${aiContext.seciliOneriKodu}${aiContext.seciliOneriAd ? ` - ${aiContext.seciliOneriAd}` : ""}`
          : "—";

    const riskIsaretleriHtml =
      Array.isArray(klinikVeri.riskIsaretleri) && klinikVeri.riskIsaretleri.length
        ? `<details style="margin-top:8px;"><summary>Klinik risk işaretleri</summary><ul class="neden-listesi">${klinikVeri.riskIsaretleri.map(x => `<li>${escapeHtml(x)}</li>`).join("")}</ul></details>`
        : "";

    const klinikOzetHtml = klinikVeri.klinikOzet
      ? `<details style="margin-top:8px;"><summary>Klinik özet</summary><div class="muted" style="margin-top:8px;">${escapeHtml(klinikVeri.klinikOzet)}</div></details>`
      : "";

    const imzaHtml = imzaKaydi
      ? `<p style="margin-top:8px;"><strong>İmza:</strong> ${escapeHtml(imzaKaydi.sertifikaNo || imzaKaydi.imzaId || "Mevcut")}</p>`
      : "";

    return `
      <div class="mini-grid">
        <div class="mini-card">
          <strong>Sonuç</strong>
          <div>${escapeHtml(r.sonuc || "-")}</div>
        </div>
        <div class="mini-card">
          <strong>Süre</strong>
          <div>${r.elapsedMs != null ? `${(r.elapsedMs / 1000).toFixed(2)}s` : "-"}</div>
        </div>
        <div class="mini-card">
          <strong>ICD</strong>
          <div>${escapeHtml(icdKodu || "-")}${icdAd ? ` - ${escapeHtml(icdAd)}` : ""}</div>
        </div>
        <div class="mini-card">
          <strong>Final SUT</strong>
          <div>${escapeHtml(secilenSut)}</div>
        </div>
        <div class="mini-card">
          <strong>HBYS Kaynağı</strong>
          <div>${escapeHtml(klinikVeri.kaynak || "-")}</div>
        </div>
        <div class="mini-card">
          <strong>Retry</strong>
          <div>${r.retryBilgi?.denendi ? "Denendi" : "Yok"}</div>
        </div>
      </div>
      ${imzaHtml}
      ${klinikOzetHtml}
      ${riskIsaretleriHtml}
    `;
  }

  if (jobId) {
    const logKutu = document.getElementById("log-kutu");
    const sonucKutu = document.getElementById("sonuc-kutu");
    const btn = document.getElementById("btn");

    logKutu.style.display = "block";
    btn.disabled = true;
    btn.textContent = "⏳ İşleniyor...";

    const es = new EventSource("/api/events/" + jobId);

    function finalizeUi() {
      btn.disabled = false;
      btn.textContent = "▶ Provizyon Al";
    }

    es.addEventListener("log", (e) => {
      const data = JSON.parse(e.data);

      logKutu.innerHTML += escapeHtml(data.message || data.line) + "<br>";
      logKutu.scrollTop = logKutu.scrollHeight;
    });

    es.addEventListener("failed", (e) => {
      const data = JSON.parse(e.data);

      es.close();
      finalizeUi();

      sonucKutu.innerHTML = `
        <div class="kirmizi">
          <h3>❌ İşlem Hatası</h3>
          <p>${escapeHtml(data.error || "Bilinmeyen hata")}</p>
        </div>`;
    });

    es.addEventListener("done", (e) => {
      const data = JSON.parse(e.data);

      es.close();
      finalizeUi();

      const r = data.result || {};

      if (r.needsHuman) {
        sonucKutu.innerHTML = `
          <div class="insan">
            <h3>⚠️ İnsan Müdahalesi Gerekiyor</h3>
            <p>Captcha veya 2FA tespit edildi.</p>
            ${renderSonucOzeti(r)}
          </div>`;
        sonucKutu.innerHTML += renderAiRapor(r.rapor);
        sonucKutu.innerHTML += renderRedCozum(r.redCozum);
        sonucKutu.innerHTML += renderRetryBilgi(r.retryBilgi);
        sonucKutu.innerHTML += renderGerekcePdf(r.gerekcePdf || r.rapor?.gerekcePdf);
        return;
      }

      if (r.hata) {
        sonucKutu.innerHTML = `
          <div class="kirmizi">
            <h3>❌ Hata</h3>
            <p>${escapeHtml(r.hata)}</p>
            ${renderSonucOzeti(r)}
          </div>`;
        sonucKutu.innerHTML += renderAiRapor(r.rapor);
        sonucKutu.innerHTML += renderRedCozum(r.redCozum);
        sonucKutu.innerHTML += renderRetryBilgi(r.retryBilgi);
        sonucKutu.innerHTML += renderGerekcePdf(r.gerekcePdf || r.rapor?.gerekcePdf);
        return;
      }

      const sonucText = String(r.sonuc || "").toUpperCase();
      const durumClass = sonucText.includes("RED") && !sonucText.includes("ONAY")
        ? "kirmizi"
        : "basarili";

      const durumTitle = sonucClassTitle(sonucText);

      sonucKutu.innerHTML = `
        <div class="${durumClass}">
          <h3>${durumTitle}</h3>
          <p><strong>Sonuç:</strong> ${escapeHtml(r.sonuc || "-")}</p>
          <p><strong>Süre:</strong> ${r.elapsedMs != null ? `${(r.elapsedMs / 1000).toFixed(2)}s` : "-"}</p>
          ${renderSonucOzeti(r)}
        </div>`;

      sonucKutu.innerHTML += renderAiRapor(r.rapor);
      sonucKutu.innerHTML += renderRedCozum(r.redCozum);
      sonucKutu.innerHTML += renderRetryBilgi(r.retryBilgi);
      sonucKutu.innerHTML += renderGerekcePdf(r.gerekcePdf || r.rapor?.gerekcePdf);
    });

    es.onerror = () => {
      if (es.readyState === EventSource.CLOSED) {
        finalizeUi();
      }
    };

    function sonucClassTitle(sonucText) {
      if (sonucText.includes("RED") && !sonucText.includes("ONAY")) {
        return "❌ İşlem RED";
      }

      if (sonucText.includes("ONAY")) {
        return "✅ Tamamlandı";
      }

      return "ℹ️ İşlem Sonucu";
    }
  }
</script>
</body>
</html>