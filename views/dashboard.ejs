<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title>Dashboard — RPA Panel</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f4ff; color: #0f172a; }
    header { background: #1a237e; color: white; padding: 14px 32px; display: flex; justify-content: space-between; align-items: center; }
    header h1 { font-size: 1.2rem; display: flex; align-items: center; gap: 10px; }
    nav a { color: #c7d2fe; text-decoration: none; margin-left: 20px; font-size: .9rem; }
    nav a:hover { color: white; }

    .hospital-badge {
      font-size: .78rem;
      background: #e8eaf6;
      color: #1a237e;
      padding: 4px 10px;
      border-radius: 999px;
      font-weight: 700;
    }

    .container { max-width: 1280px; margin: 32px auto; padding: 0 16px; }

    .tasarruf-banner {
      background: linear-gradient(135deg, #1a237e, #4361ee);
      color: white;
      border-radius: 14px;
      padding: 24px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
      box-shadow: 0 4px 16px rgba(67,97,238,.3);
      gap: 24px;
      flex-wrap: wrap;
    }

    .tasarruf-banner .buyuk { font-size: 2.4rem; font-weight: 800; }
    .tasarruf-banner .kucuk { font-size: .95rem; opacity: .9; margin-top: 4px; }

    .tasarruf-detay { display: flex; gap: 26px; flex-wrap: wrap; }
    .tasarruf-detay div { text-align: center; }
    .tasarruf-detay .sayi { font-size: 1.4rem; font-weight: 700; }
    .tasarruf-detay .etiket { font-size: .8rem; opacity: .85; }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }

    .kpi {
      background: white;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      border-left: 4px solid #4361ee;
      box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }

    .kpi.yesil  { border-color: #16a34a; }
    .kpi.kirmizi{ border-color: #dc2626; }
    .kpi.sari   { border-color: #d97706; }
    .kpi.mor    { border-color: #7c3aed; }
    .kpi.gri    { border-color: #475569; }
    .kpi.lacivert { border-color: #1d4ed8; }

    .kpi-deger  { font-size: 1.9rem; font-weight: 700; color: #1a237e; }
    .kpi-etiket { font-size: .85rem; color: #666; margin-top: 4px; }
    .kpi-alt    { font-size: .75rem; color: #94a3b8; margin-top: 2px; }

    .kart {
      background: white;
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,.08);
      margin-bottom: 24px;
    }

    .kart h2 { color: #1a237e; margin-bottom: 16px; font-size: 1.08rem; }

    .iki-kolon {
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 20px;
      margin-bottom: 24px;
    }

    .uc-kolon {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 24px;
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }

    .mini-kart {
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 14px;
    }

    .mini-kart strong {
      display: block;
      color: #334155;
      margin-bottom: 6px;
      font-size: .9rem;
    }

    .mini-kart div {
      font-size: 1.25rem;
      font-weight: 700;
      color: #1e3a8a;
    }

    .oran-blok { margin-top: 14px; }
    .oran-baslik { margin-bottom: 8px; font-weight: 600; color: #334155; }
    .oran-wrap { background: #e5e7eb; border-radius: 999px; height: 18px; overflow: hidden; }
    .oran-bar { height: 100%; }
    .oran-text { font-size: .9rem; color: #555; margin-top: 4px; }

    .bar-wrap {
      display: flex;
      align-items: flex-end;
      gap: 12px;
      height: 160px;
    }

    .bar-col  {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      flex: 1;
      min-width: 0;
    }

    .bar {
      background: #4361ee;
      border-radius: 4px 4px 0 0;
      width: 100%;
      min-height: 4px;
      transition: height .3s;
    }

    .bar.red { background: #ef4444; }
    .bar.yellow { background: #f59e0b; }
    .bar.green { background: #22c55e; }
    .bar.indigo { background: #6366f1; }

    .bar-label{
      font-size: .75rem;
      color: #888;
      text-align: center;
      word-break: break-word;
    }

    .bar-val  {
      font-size: .8rem;
      font-weight: 600;
      color: #1a237e;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1.2fr 180px 180px;
      gap: 12px;
      margin-bottom: 14px;
    }

    .alan label {
      display: block;
      font-size: .85rem;
      color: #475569;
      margin-bottom: 6px;
      font-weight: 600;
    }

    .alan input,
    .alan textarea,
    .alan button {
      width: 100%;
      padding: 12px;
      border-radius: 10px;
      border: 1px solid #cbd5e1;
      font: inherit;
    }

    .alan textarea {
      min-height: 110px;
      resize: vertical;
    }

    .alan button {
      background: #1d4ed8;
      color: white;
      border: none;
      cursor: pointer;
      font-weight: 700;
      margin-top: 24px;
    }

    .alan button:hover { background: #1e40af; }

    .ai-box {
      background: #f8fafc;
      border: 1px solid #dbeafe;
      border-radius: 12px;
      padding: 16px;
      margin-top: 12px;
    }

    .ai-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 12px;
    }

    .ai-chip {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      background: #eff6ff;
      color: #1d4ed8;
      font-size: .8rem;
      font-weight: 700;
      margin: 4px 6px 0 0;
    }

    .ai-muted { color: #64748b; font-size: .9rem; }
    .ai-title { color: #0f172a; font-weight: 700; margin-bottom: 6px; }
    .ai-list { margin-top: 8px; padding-left: 18px; color: #334155; }
    .ai-list li { margin-bottom: 6px; }

    .confidence-good { color: #15803d; font-weight: 700; }
    .confidence-mid { color: #b45309; font-weight: 700; }
    .confidence-low { color: #b91c1c; font-weight: 700; }

    .heatmap-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
    }

    .heat-card {
      border-radius: 12px;
      padding: 16px;
      border: 1px solid #e5e7eb;
      background: #fff;
    }

    .heat-card.high {
      background: #fef2f2;
      border-color: #fecaca;
    }

    .heat-card.mid {
      background: #fffbeb;
      border-color: #fde68a;
    }

    .heat-card.low {
      background: #f0fdf4;
      border-color: #bbf7d0;
    }

    .heat-card .title {
      font-size: .82rem;
      color: #475569;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .heat-card .value {
      font-size: 1.35rem;
      font-weight: 800;
      color: #0f172a;
      margin-bottom: 4px;
      word-break: break-word;
    }

    .heat-card .sub {
      font-size: .85rem;
      color: #64748b;
      line-height: 1.4;
    }

    table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    th { padding: 10px; text-align: left; background: #f0f4ff; }
    td { padding: 10px; border-bottom: 1px solid #eef2f7; vertical-align: top; }

    .badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: .78rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .badge.low { background: #dcfce7; color: #166534; }
    .badge.mid { background: #fef3c7; color: #92400e; }
    .badge.high { background: #fee2e2; color: #991b1b; }
    .badge.info { background: #e0e7ff; color: #3730a3; }

    .liste { list-style: none; padding-left: 0; }
    .liste li {
      padding: 10px 0;
      border-bottom: 1px solid #eef2f7;
      font-size: .92rem;
    }

    .muted { color: #64748b; }
    .hidden { display: none; }
    .table-wrap { overflow-x: auto; }

    @media (max-width: 1100px) {
      .iki-kolon,
      .uc-kolon,
      .form-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
<header>
  <h1>
    🏥 RPA Provizyon Paneli
    <% if (typeof currentHospital !== "undefined" && currentHospital) { %>
      <span class="hospital-badge"><%= currentHospital.ad %></span>
    <% } %>
  </h1>
  <nav>
    <% const role = String(currentUser?.role || ""); %>
    <% const isAdmin = role === "admin" || String(currentUser?.username || "").toLowerCase() === "admin"; %>

    <% if (role === "operator" || isAdmin) { %>
      <a href="/">🤖 Bot</a>
    <% } %>

    <% if (role === "history" || role === "viewer" || role === "operator" || isAdmin || role === "kvkk_officer") { %>
      <a href="/history">📋 Geçmiş</a>
    <% } %>

    <% if (role === "operator" || isAdmin) { %>
      <a href="/credentials">🔑 Credentials</a>
    <% } %>

    <a href="/monitoring">📈 Monitoring</a>

    <% if (isAdmin) { %>
      <a href="/admin/users">🏢 SaaS Admin</a>
      <a href="/admin/audit">🔒 Audit</a>
    <% } %>

    <a href="/logout">Çıkış</a>
  </nav>
</header>

<div class="container">

  <%
    const safeDaily = Array.isArray(daily) ? daily : [];
    const safeItems = Array.isArray(items) ? items : [];
    const safeAiOzet = aiOzet || { toplam: 0, onay: 0, red: 0, aiBloke: 0, ortSure: 0, ortRisk: 0, retrySuccessRate: 0, calibrationError: 0 };
    const safeStats = stats || { total: 0, ok: 0, red: 0, fail: 0, aiBloke: 0, needsHuman: 0 };
    const safeProviderPerformance = Array.isArray(providerPerformance) ? providerPerformance : [];
    const safeProcedurePerformance = Array.isArray(procedurePerformance) ? procedurePerformance : [];
    const safeTopRedReasons = Array.isArray(topRedReasons) ? topRedReasons : [];
    const safeTopMissingDocuments = Array.isArray(topMissingDocuments) ? topMissingDocuments : [];
    const safeKeywordPatterns = Array.isArray(keywordPatterns) ? keywordPatterns : [];
    const safeTopPredictions = Array.isArray(topPredictions) ? topPredictions : [];
    const safeQueue = queue || { activeWorkers: 0, queued: 0, maxWorkers: 0, deadJobs: 0 };
    const safeCharts = dashboardCharts || { outcomes: { labels: [], values: [] }, daily: { labels: [], values: [] }, providers: { labels: [], values: [] }, procedures: { labels: [], values: [] } };

    const MANUEL_SURE_SN = 300;
    const avgElapsedMs = safeItems.length
      ? safeItems.reduce((sum, x) => sum + Number(x.elapsedMs || 0), 0) / safeItems.length
      : 0;
    const botSureSn = avgElapsedMs > 0 ? avgElapsedMs / 1000 : 0;
    const islemBasinaKazanilanSn = Math.max(0, MANUEL_SURE_SN - botSureSn);
    const toplamKazanilanSn = Math.round(islemBasinaKazanilanSn * (safeStats.total || 0));
    const toplamKazanilanDk  = Math.round(toplamKazanilanSn / 60);
    const toplamKazanilanSaat = (toplamKazanilanDk / 60).toFixed(1);

    const SAAT_UCRET = 150;
    const paraTasarrufu = Math.round((toplamKazanilanSn / 3600) * SAAT_UCRET);

    const toplam = Number(safeAiOzet.toplam || 0);
    const onayOrani = toplam ? Math.round((Number(safeAiOzet.onay || 0) / toplam) * 100) : 0;
    const redOrani = toplam ? Math.round((Number(safeAiOzet.red || 0) / toplam) * 100) : 0;
    const aiBlokeOrani = toplam ? Math.round((Number(safeAiOzet.aiBloke || 0) / toplam) * 100) : 0;
    const retrySuccessRate = Number(safeAiOzet.retrySuccessRate || 0);

    const highestProcedure = safeProcedurePerformance[0] || null;
    const highestProvider = safeProviderPerformance[0] || null;
    const topReason = safeTopRedReasons[0] || null;
    const topPrediction = safeTopPredictions[0] || null;
  %>

  <div class="tasarruf-banner">
    <div>
      <div class="buyuk">⏱ <%= toplamKazanilanSaat %> saat</div>
      <div class="kucuk">toplam tasarruf edilen personel süresi (<%= safeStats.total || 0 %> işlemde)</div>
    </div>
    <div class="tasarruf-detay">
      <div>
        <div class="sayi"><%= islemBasinaKazanilanSn.toFixed(0) %>s</div>
        <div class="etiket">işlem başına kazanç</div>
      </div>
      <div>
        <div class="sayi"><%= toplamKazanilanDk %> dk</div>
        <div class="etiket">toplam süre</div>
      </div>
      <div>
        <div class="sayi">₺<%= paraTasarrufu.toLocaleString("tr-TR") %></div>
        <div class="etiket">tahmini maliyet tasarrufu</div>
      </div>
    </div>
  </div>

  <div class="kpi-grid">
    <div class="kpi yesil">
      <div class="kpi-deger" id="kpi-total"><%= safeStats.total || 0 %></div>
      <div class="kpi-etiket">Toplam İşlem</div>
    </div>
    <div class="kpi yesil">
      <div class="kpi-deger" id="kpi-success"><%= successRate || 0 %>%</div>
      <div class="kpi-etiket">Başarı Oranı</div>
    </div>
    <div class="kpi lacivert">
      <div class="kpi-deger" id="kpi-onay"><%= safeStats.ok || 0 %></div>
      <div class="kpi-etiket">Onaylanan</div>
    </div>
    <div class="kpi kirmizi">
      <div class="kpi-deger" id="kpi-red"><%= safeStats.red || 0 %></div>
      <div class="kpi-etiket">Reddedilen</div>
    </div>
    <div class="kpi sari">
      <div class="kpi-deger"><%= Number(safeAiOzet.ortSure || 0).toFixed(2) %>s</div>
      <div class="kpi-etiket">Ort. Bot Süresi</div>
      <div class="kpi-alt">Manuel: <%= MANUEL_SURE_SN %>s</div>
    </div>
    <div class="kpi mor">
      <div class="kpi-deger" id="kpi-aibloke"><%= safeStats.aiBloke || safeAiOzet.aiBloke || 0 %></div>
      <div class="kpi-etiket">AI Bloke</div>
    </div>
    <div class="kpi gri">
      <div class="kpi-deger" id="kpi-workers"><%= safeQueue.activeWorkers || 0 %> / <%= safeQueue.maxWorkers || 0 %></div>
      <div class="kpi-etiket">Aktif Worker</div>
    </div>
    <div class="kpi kirmizi">
      <div class="kpi-deger" id="kpi-dead"><%= safeQueue.deadJobs || 0 %></div>
      <div class="kpi-etiket">Dead Job</div>
    </div>
  </div>

  <!-- Sistem Sağlığı + Canlı Kuyruk -->
  <div class="iki-kolon">
    <div class="kart">
      <h2>🖥 Sistem Sağlığı <span id="live-dot" style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#22c55e;margin-left:8px;animation:pulse 2s infinite;"></span></h2>
      <div class="mini-grid">
        <div class="mini-kart">
          <strong>Uptime</strong>
          <div id="sys-uptime">—</div>
        </div>
        <div class="mini-kart">
          <strong>RAM Kullanımı</strong>
          <div id="sys-memory">—</div>
        </div>
        <div class="mini-kart">
          <strong>Node Versiyonu</strong>
          <div id="sys-node">—</div>
        </div>
        <div class="mini-kart">
          <strong>Son Güncelleme</strong>
          <div id="sys-last-update">—</div>
        </div>
      </div>
      <div style="margin-top:12px;font-size:.8rem;color:#94a3b8;" id="auto-refresh-info">
        🔄 Her 30 saniyede otomatik güncellenir
      </div>
    </div>
    <div class="kart">
      <h2>📡 Canlı Kuyruk Durumu</h2>
      <div class="mini-grid">
        <div class="mini-kart">
          <strong>Bekleyen İşler</strong>
          <div id="queue-pending" style="font-size:1.6rem;font-weight:800;color:#d97706;"><%= safeQueue.queued || 0 %></div>
        </div>
        <div class="mini-kart">
          <strong>Aktif Worker</strong>
          <div id="queue-workers" style="font-size:1.6rem;font-weight:800;color:#16a34a;"><%= safeQueue.activeWorkers || 0 %> / <%= safeQueue.maxWorkers || 0 %></div>
        </div>
        <div class="mini-kart">
          <strong>Dead Jobs</strong>
          <div id="queue-dead" style="font-size:1.6rem;font-weight:800;color:#dc2626;"><%= safeQueue.deadJobs || 0 %></div>
        </div>
      </div>
      <div id="queue-bar" style="margin-top:14px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
          <span style="font-size:.85rem;font-weight:600;color:#334155;">Worker Yükü</span>
          <span id="queue-load-pct" style="font-size:.85rem;color:#64748b;">0%</span>
        </div>
        <div style="background:#e5e7eb;border-radius:999px;height:12px;overflow:hidden;">
          <div id="queue-load-bar" style="height:100%;background:#4361ee;border-radius:999px;transition:width .5s;width:0%;"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="kart">
    <h2>🔥 RED Risk Heatmap</h2>
    <div class="heatmap-grid">
      <div class="heat-card <%= highestProcedure && Number(highestProcedure.redOrani || 0) >= 0.5 ? "high" : highestProcedure && Number(highestProcedure.redOrani || 0) >= 0.25 ? "mid" : "low" %>">
        <div class="title">En Riskli SUT</div>
        <div class="value"><%= highestProcedure ? highestProcedure.kod : "-" %></div>
        <div class="sub">
          <% if (highestProcedure) { %>
            Toplam <%= highestProcedure.toplam %> kayıt, RED oranı <%= Math.round(Number(highestProcedure.redOrani || 0) * 100) %>%
          <% } else { %>
            Veri yok.
          <% } %>
        </div>
      </div>

      <div class="heat-card <%= highestProvider && Number(highestProvider.redOrani || 0) >= 0.5 ? "high" : highestProvider && Number(highestProvider.redOrani || 0) >= 0.25 ? "mid" : "low" %>">
        <div class="title">En Riskli Provider</div>
        <div class="value"><%= highestProvider ? highestProvider.provider : "-" %></div>
        <div class="sub">
          <% if (highestProvider) { %>
            Toplam <%= highestProvider.toplam %> kayıt, RED oranı <%= Math.round(Number(highestProvider.redOrani || 0) * 100) %>%
          <% } else { %>
            Veri yok.
          <% } %>
        </div>
      </div>

      <div class="heat-card <%= topPrediction && Number(topPrediction.risk || 0) >= 0.7 ? "high" : topPrediction && Number(topPrediction.risk || 0) >= 0.4 ? "mid" : "low" %>">
        <div class="title">En Riskli Tahmin</div>
        <div class="value">
          <%= topPrediction ? Math.round(Number(topPrediction.risk || 0) * 100) + "%" : "-" %>
        </div>
        <div class="sub">
          <% if (topPrediction) { %>
            İşlem: <%= topPrediction.islem_kodu || "-" %> | Provider: <%= topPrediction.provider || "-" %>
          <% } else { %>
            Veri yok.
          <% } %>
        </div>
      </div>

      <div class="heat-card <%= topReason && Number(topReason.adet || 0) >= 5 ? "high" : topReason && Number(topReason.adet || 0) >= 2 ? "mid" : "low" %>">
        <div class="title">En Sık RED Nedeni</div>
        <div class="value"><%= topReason ? topReason.neden : "-" %></div>
        <div class="sub">
          <% if (topReason) { %>
            <%= topReason.adet %> kez görüldü
          <% } else { %>
            Veri yok.
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <% if (role === "operator" || isAdmin) { %>
    <div class="iki-kolon">
      <div class="kart">
        <h2>🧠 AI ICD / SUT Öneri Paneli</h2>

        <div class="form-grid">
          <div class="alan">
            <label for="aiDoktorNotu">Doktor Notu</label>
            <textarea id="aiDoktorNotu" placeholder="Örn: Kronik böbrek yetmezliği evre 4, kreatinin yüksek, nefroloji kontrolü"></textarea>
          </div>

          <div class="alan">
            <label for="aiYas">Yaş</label>
            <input id="aiYas" type="number" min="0" max="120" placeholder="Örn: 68">
          </div>

          <div class="alan">
            <button id="aiOneriBtn" type="button">AI Öneri Getir</button>
          </div>
        </div>

        <div id="aiError" class="ai-box hidden" style="border-color:#fecaca;background:#fef2f2;color:#991b1b;"></div>

        <div id="aiResult" class="ai-box hidden">
          <div class="ai-row">
            <div class="mini-kart">
              <strong>Ana ICD</strong>
              <div id="aiIcdKod">-</div>
              <div class="ai-muted" id="aiIcdAd">-</div>
            </div>

            <div class="mini-kart">
              <strong>Güven Skoru</strong>
              <div id="aiConfidence">-</div>
              <div class="ai-muted">AI eşleşme güveni</div>
            </div>

            <div class="mini-kart">
              <strong>Açıklama</strong>
              <div id="aiAciklama" style="font-size:1rem; line-height:1.4;">-</div>
            </div>
          </div>

          <div style="margin-top:14px;">
            <div class="ai-title">ICD Adayları</div>
            <div id="aiIcdAdaylari" class="ai-muted">Henüz veri yok.</div>
          </div>

          <div style="margin-top:18px;">
            <div class="ai-title">SUT Önerileri</div>
            <ul id="aiSutOnerileri" class="ai-list"></ul>
          </div>
        </div>
      </div>

      <div class="kart">
        <h2>🧠 AI Provizyon Özeti</h2>

        <div class="mini-grid">
          <div class="mini-kart">
            <strong>Toplam İşlem</strong>
            <div><%= safeAiOzet.toplam || 0 %></div>
          </div>
          <div class="mini-kart">
            <strong>ONAY</strong>
            <div><%= safeAiOzet.onay || 0 %></div>
          </div>
          <div class="mini-kart">
            <strong>RED</strong>
            <div><%= safeAiOzet.red || 0 %></div>
          </div>
          <div class="mini-kart">
            <strong>AI Bloke</strong>
            <div><%= safeAiOzet.aiBloke || 0 %></div>
          </div>
          <div class="mini-kart">
            <strong>Ort. Süre</strong>
            <div><%= Number(safeAiOzet.ortSure || 0).toFixed(2) %> sn</div>
          </div>
          <div class="mini-kart">
            <strong>Ort. Risk</strong>
            <div><%= safeAiOzet.ortRisk || 0 %></div>
          </div>
        </div>

        <div class="oran-blok">
          <div class="oran-baslik">ONAY Oranı</div>
          <div class="oran-wrap">
            <div class="oran-bar" style="width:<%= onayOrani %>%; background:#22c55e;"></div>
          </div>
          <div class="oran-text"><%= onayOrani %>%</div>
        </div>

        <div class="oran-blok">
          <div class="oran-baslik">RED Oranı</div>
          <div class="oran-wrap">
            <div class="oran-bar" style="width:<%= redOrani %>%; background:#ef4444;"></div>
          </div>
          <div class="oran-text"><%= redOrani %>%</div>
        </div>

        <div class="oran-blok">
          <div class="oran-baslik">AI Bloke Oranı</div>
          <div class="oran-wrap">
            <div class="oran-bar" style="width:<%= aiBlokeOrani %>%; background:#f59e0b;"></div>
          </div>
          <div class="oran-text"><%= aiBlokeOrani %>%</div>
        </div>

        <div class="oran-blok">
          <div class="oran-baslik">Retry Başarı Oranı</div>
          <div class="oran-wrap">
            <div class="oran-bar" style="width:<%= Math.round(retrySuccessRate * 100) %>%; background:#6366f1;"></div>
          </div>
          <div class="oran-text"><%= Math.round(retrySuccessRate * 100) %>%</div>
        </div>

        <div class="oran-blok">
          <div class="oran-baslik">Model Calibration Error</div>
          <div class="oran-text"><%= safeAiOzet.calibrationError || 0 %></div>
        </div>
      </div>
    </div>
  <% } %>

  <div class="uc-kolon">
    <div class="kart">
      <h2>📅 Günlük İşlem Trendi</h2>
      <% const maxCount = Math.max(...(safeDaily.map(d => Number(d.count) || 0)), 1); %>
      <% if (safeDaily.length === 0) { %>
        <div class="muted">Henüz veri yok.</div>
      <% } else { %>
        <div class="bar-wrap">
          <% safeDaily.forEach(function(d) { %>
            <div class="bar-col">
              <div class="bar-val"><%= d.count %></div>
              <div class="bar indigo" style="height: <%= Math.round(((Number(d.count)||0)/maxCount)*120) %>px"></div>
              <div class="bar-label"><%= String(d.date || d.day || "").slice(5) %></div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="kart">
      <h2>🏢 Provider RED Oranı</h2>
      <% const providerMax = Math.max(...(safeCharts.providers.values || [1]), 1); %>
      <% if (!safeCharts.providers.labels.length) { %>
        <div class="muted">Veri yok.</div>
      <% } else { %>
        <div class="bar-wrap">
          <% safeCharts.providers.labels.forEach(function(label, idx) { %>
            <% const val = Number((safeCharts.providers.values || [])[idx] || 0); %>
            <div class="bar-col">
              <div class="bar-val"><%= Math.round(val * 100) %>%</div>
              <div class="bar red" style="height:<%= Math.max(8, Math.round((val / providerMax) * 120)) %>px"></div>
              <div class="bar-label"><%= label %></div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="kart">
      <h2>🧾 İşlem RED Oranı</h2>
      <% const procMax = Math.max(...(safeCharts.procedures.values || [1]), 1); %>
      <% if (!safeCharts.procedures.labels.length) { %>
        <div class="muted">Veri yok.</div>
      <% } else { %>
        <div class="bar-wrap">
          <% safeCharts.procedures.labels.forEach(function(label, idx) { %>
            <% const val = Number((safeCharts.procedures.values || [])[idx] || 0); %>
            <div class="bar-col">
              <div class="bar-val"><%= Math.round(val * 100) %>%</div>
              <div class="bar yellow" style="height:<%= Math.max(8, Math.round((val / procMax) * 120)) %>px"></div>
              <div class="bar-label"><%= label %></div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <div class="iki-kolon">
    <div class="kart">
      <h2>❗ En Sık Red Nedenleri</h2>
      <ul class="liste">
        <% if (!safeTopRedReasons.length) { %>
          <li class="muted">Veri yok.</li>
        <% } %>
        <% safeTopRedReasons.slice(0, 10).forEach(function(x) { %>
          <li>
            <strong><%= x.neden %></strong><br>
            <span class="muted"><%= x.adet %> kez</span>
          </li>
        <% }) %>
      </ul>
    </div>

    <div class="kart">
      <h2>📎 En Sık Eksik Belgeler</h2>
      <ul class="liste">
        <% if (!safeTopMissingDocuments.length) { %>
          <li class="muted">Veri yok.</li>
        <% } %>
        <% safeTopMissingDocuments.slice(0, 10).forEach(function(x) { %>
          <li>
            <strong><%= x.belge %></strong><br>
            <span class="muted"><%= x.adet %> kez</span>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>

  <div class="iki-kolon">
    <div class="kart">
      <h2>🏷 Doktor Notu Paternleri</h2>
      <ul class="liste">
        <% if (!safeKeywordPatterns.length) { %>
          <li class="muted">Veri yok.</li>
        <% } %>
        <% safeKeywordPatterns.slice(0, 10).forEach(function(x) { %>
          <li>
            <strong><%= x.etiket %></strong> — <%= x.islem_kodu %><br>
            <span class="muted">Yaş grubu: <%= x.yas_grubu %> | Örnek: <%= x.toplam %> | Red oranı: <%= Math.round((x.redOrani || 0) * 100) %>%</span>
          </li>
        <% }) %>
      </ul>
    </div>

    <div class="kart">
      <h2>🔮 En Riskli Tahminler</h2>
      <ul class="liste">
        <% if (!safeTopPredictions.length) { %>
          <li class="muted">Veri yok.</li>
        <% } %>
        <% safeTopPredictions.slice(0, 10).forEach(function(x) { %>
          <li>
            <strong><%= x.islem_kodu || "BILINMIYOR" %></strong>
            <% if ((x.seviye || "").includes("YÜKSEK")) { %>
              <span class="badge high"><%= x.seviye %></span>
            <% } else if ((x.seviye || "").includes("ORTA")) { %>
              <span class="badge mid"><%= x.seviye %></span>
            <% } else { %>
              <span class="badge low"><%= x.seviye %></span>
            <% } %>
            <br>
            <span class="muted">
              Provider: <%= x.provider || "-" %> |
              Risk: <%= Math.round((x.risk || 0) * 100) %>% |
              Confidence: <%= Math.round((x.confidence || 0) * 100) %>%
            </span>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>

  <div class="kart">
    <h2>📋 Son İşlemler</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Zaman</th>
            <th>TC</th>
            <th>İşlem</th>
            <th>Sonuç</th>
            <th>Risk</th>
            <th>Bot Süresi</th>
            <th>Kazanılan</th>
          </tr>
        </thead>
        <tbody>
          <% if (safeItems.length === 0) { %>
            <tr><td colspan="7" class="muted">Kayıt yok.</td></tr>
          <% } %>
          <% safeItems.forEach(function(item) {
               const botSure = Number(item.elapsedMs) > 0 ? Number(item.elapsedMs) / 1000 : null;
               const kazanilan = botSure ? Math.max(0, MANUEL_SURE_SN - botSure).toFixed(0) : null;
               const sonucText = String(item.sonuc || "").toUpperCase();
          %>
          <tr>
            <td><%= new Date(item.createdAt || item.time || Date.now()).toLocaleString('tr-TR') %></td>
           <td>*******<%= String(item.tcKimlikNo || item.tc || "").slice(-4) %></td>
            <td>
              <strong><%= item.islem_kodu || item.provizyonTipi || "BILINMIYOR" %></strong><br>
              <span class="muted"><%= item.islem_adi || "Bilinmeyen İşlem" %></span>
            </td>
            <td>
              <% if (item.hata) { %>
                <span class="badge high">HATA</span>
              <% } else if (sonucText.includes('AI BLOKE')) { %>
                <span class="badge mid">AI BLOKE</span>
              <% } else if (sonucText.includes('ONAY')) { %>
                <span class="badge low">ONAY</span>
              <% } else { %>
                <span class="badge high">RED</span>
              <% } %>
            </td>
           <td>
<%= Number(item.ai_risk) ? Math.round(Number(item.ai_risk) * 100) + "%" : "—" %>
</td>
            <td><%= botSure != null ? botSure.toFixed(2) + 's' : '—' %></td>
            <td style="color:#16a34a;font-weight:700"><%= kazanilan ? '+' + kazanilan + 's' : '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script>
  const aiBtn = document.getElementById("aiOneriBtn");
  const aiDoktorNotu = document.getElementById("aiDoktorNotu");
  const aiYas = document.getElementById("aiYas");
  const aiResult = document.getElementById("aiResult");
  const aiError = document.getElementById("aiError");

  function confidenceClass(value) {
    const n = Number(value || 0);
    if (n >= 0.8) return "confidence-good";
    if (n >= 0.5) return "confidence-mid";
    return "confidence-low";
  }

  function formatPercent(value) {
    return `${Math.round(Number(value || 0) * 100)}%`;
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  if (aiBtn) {
    aiBtn.addEventListener("click", async () => {
      aiError.classList.add("hidden");
      aiResult.classList.add("hidden");
      aiError.textContent = "";

      const doktorNotu = aiDoktorNotu.value.trim();
      const yas = aiYas.value.trim();

      if (!doktorNotu) {
        aiError.textContent = "Doktor notu gerekli.";
        aiError.classList.remove("hidden");
        return;
      }

      aiBtn.disabled = true;
      aiBtn.textContent = "Analiz ediliyor...";

      try {
        const res = await fetch("/api/icd-sut-oner", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          body: JSON.stringify({
            doktorNotu,
            yas: yas || null
          })
        });

        const data = await res.json();

        if (!res.ok || !data.ok) {
          throw new Error(data?.hata || "AI önerisi alınamadı");
        }

        const veri = data.veri || {};
        const anaIcd = veri.icd || null;

        document.getElementById("aiIcdKod").textContent = anaIcd?.icd || "-";
        document.getElementById("aiIcdAd").textContent = anaIcd?.ad || "ICD bulunamadı";

        const confEl = document.getElementById("aiConfidence");
        confEl.textContent = formatPercent(veri.confidence || 0);
        confEl.className = confidenceClass(veri.confidence || 0);

        document.getElementById("aiAciklama").textContent = veri.aciklama || "-";

        const icdAdaylariEl = document.getElementById("aiIcdAdaylari");
        const adaylar = Array.isArray(veri.icdAdaylari) ? veri.icdAdaylari : [];
        if (!adaylar.length) {
          icdAdaylariEl.innerHTML = '<span class="ai-muted">ICD adayı bulunamadı.</span>';
        } else {
          icdAdaylariEl.innerHTML = adaylar.map((x) =>
            `<span class="ai-chip">${escapeHtml(x.icd)} - ${escapeHtml(x.ad)} (${formatPercent(x.confidence)})</span>`
          ).join("");
        }

        const sutEl = document.getElementById("aiSutOnerileri");
        const oneriler = Array.isArray(veri.oneriler) ? veri.oneriler : [];
        if (!oneriler.length) {
          sutEl.innerHTML = "<li>Uygun SUT önerisi bulunamadı.</li>";
        } else {
          sutEl.innerHTML = oneriler.map((x) => `
            <li>
              <strong>${escapeHtml(x.kod || "-")} - ${escapeHtml(x.ad || "-")}</strong>
              ${x.aciklama ? `<div class="ai-muted">${escapeHtml(x.aciklama)}</div>` : ""}
              ${Array.isArray(x.belgeler) && x.belgeler.length
                ? `<div class="ai-muted">Belgeler: ${x.belgeler.map(escapeHtml).join(", ")}</div>`
                : ""}
            </li>
          `).join("");
        }

        aiResult.classList.remove("hidden");
      } catch (err) {
        aiError.textContent = err.message || "Bir hata oluştu.";
        aiError.classList.remove("hidden");
      } finally {
        aiBtn.disabled = false;
        aiBtn.textContent = "AI Öneri Getir";
      }
    });
  }
</script>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .3; }
  }
  .live-feed-row {
    display: grid;
    grid-template-columns: 130px 90px 100px 80px 70px;
    gap: 8px;
    padding: 6px 0;
    border-bottom: 1px solid #f0f0f0;
    font-size: .85rem;
    align-items: center;
  }
  .live-feed-row:last-child { border-bottom: none; }
  .live-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: .72rem;
    font-weight: 700;
  }
  .live-badge.onay { background: #dcfce7; color: #166534; }
  .live-badge.red { background: #fee2e2; color: #991b1b; }
  .live-badge.bloke { background: #fef3c7; color: #92400e; }
</style>

<script>
// ── Auto-Refresh Dashboard ──────────────────────────────────────────
const REFRESH_INTERVAL = 30000; // 30 saniye
let refreshTimer = null;

async function refreshDashboard() {
  try {
    const res = await fetch('/api/dashboard/live');
    const data = await res.json();
    if (!data.ok) return;

    // KPI güncelle
    const s = data.stats;
    setText('kpi-total', s.total);
    setText('kpi-success', s.successRate + '%');
    setText('kpi-onay', s.ok);
    setText('kpi-red', s.red);
    setText('kpi-aibloke', s.aiBloke);

    // Kuyruk güncelle
    const q = data.queue;
    setText('kpi-workers', q.activeWorkers + ' / ' + q.maxWorkers);
    setText('kpi-dead', q.deadJobs);
    setText('queue-pending', q.queued);
    setText('queue-workers', q.activeWorkers + ' / ' + q.maxWorkers);
    setText('queue-dead', q.deadJobs);

    // Worker yükü bar
    const loadPct = q.maxWorkers > 0 ? Math.round((q.activeWorkers / q.maxWorkers) * 100) : 0;
    setText('queue-load-pct', loadPct + '%');
    const bar = document.getElementById('queue-load-bar');
    if (bar) {
      bar.style.width = loadPct + '%';
      bar.style.background = loadPct > 80 ? '#dc2626' : loadPct > 50 ? '#f59e0b' : '#4361ee';
    }

    // Sistem sağlığı güncelle
    const sys = data.system;
    setText('sys-uptime', formatUptime(sys.uptimeDk));
    setText('sys-memory', sys.memoryMB + ' / ' + sys.memoryTotalMB + ' MB');
    setText('sys-node', sys.nodeVersion);
    setText('sys-last-update', new Date().toLocaleTimeString('tr-TR'));

    // Son işlemler canlı feed
    const feedEl = document.getElementById('live-feed');
    if (feedEl && data.sonIslemler && data.sonIslemler.length > 0) {
      feedEl.innerHTML = data.sonIslemler.map(item => {
        const zamanStr = item.zaman ? new Date(item.zaman).toLocaleTimeString('tr-TR') : '-';
        const badgeClass = item.sonuc.includes('ONAY') ? 'onay' : item.sonuc.includes('AI BLOKE') ? 'bloke' : 'red';
        return `<div class="live-feed-row">
          <span>${zamanStr}</span>
          <span>${escapeHtml(item.tc)}</span>
          <span><strong>${escapeHtml(item.islem)}</strong></span>
          <span class="live-badge ${badgeClass}">${escapeHtml(item.sonuc.substring(0,10))}</span>
          <span>${item.sure ? item.sure + 's' : '—'}</span>
        </div>`;
      }).join('');
    }

  } catch (err) {
    console.warn('[Dashboard refresh]', err.message);
  }
}

function setText(id, value) {
  const el = document.getElementById(id);
  if (el) el.textContent = value;
}

function formatUptime(dk) {
  if (dk < 60) return dk + ' dk';
  const saat = Math.floor(dk / 60);
  const kalanDk = dk % 60;
  if (saat < 24) return saat + ' saat ' + kalanDk + ' dk';
  const gun = Math.floor(saat / 24);
  return gun + ' gün ' + (saat % 24) + ' saat';
}

// İlk yükleme + timer başlat
refreshDashboard();
refreshTimer = setInterval(refreshDashboard, REFRESH_INTERVAL);
</script>
</body>
</html>